# Public site URL (no trailing slash). Used for canonical, OG, hreflang, sitemap.
SITE_URL=https://chirping-astro.example.com

# Sub-path the site is served from. Leave blank (or set to "/") for local
# dev and root-domain hosting; set to "/<repo>" when deploying to GitHub
# Pages so all asset URLs resolve correctly.
#   examples:  BASE_PATH=/chirping-astro     (GitHub Pages)
#              BASE_PATH=                    (root domain or `bun run dev`)
BASE_PATH=

# --- Author / social handles ---
# Filling these in lets `src/config.ts` build all GitHub / Twitter / email
# URLs for you, so you never have to edit URLs by hand. Leave any of them
# blank to drop the corresponding social icon from the sidebar.
PUBLIC_GITHUB_HANDLE=
# Optional repository slug for custom integrations (not used by the default footer theme link).
PUBLIC_GITHUB_REPO=chirping-astro
PUBLIC_TWITTER_HANDLE=
PUBLIC_CONTACT_EMAIL=

# --- Telegram comments ---
# Posts opt in via frontmatter: telegramPostId: 5
PUBLIC_TELEGRAM_COMMENTS_ENABLED=true
PUBLIC_TELEGRAM_CHANNEL=

---
import '../styles/global.css';

import { Font } from 'astro:assets';
import Sidebar from '../components/Sidebar.astro';
import Topbar from '../components/Topbar.astro';
import Footer from '../components/Footer.astro';
import Panel from '../components/Panel.astro';
import SEO from '../components/SEO.astro';
import BackToTop from '../components/islands/BackToTop.astro';
import { ClientRouter } from 'astro:transitions';
import faviconImg from '../assets/images/site/favicon.png';
import favicon64Img from '../assets/images/site/favicon64.png';
import favicon120Img from '../assets/images/site/favicon120.png';
import favicon152Img from '../assets/images/site/favicon152.png';
import favicon167Img from '../assets/images/site/favicon167.png';
import favicon180Img from '../assets/images/site/favicon180.png';
import favicon240Img from '../assets/images/site/favicon240.png';
import { htmlLang, useTranslations, withBase } from '../i18n/utils';
import { buildSeo, type SeoMeta } from '../utils/seo';
import { SITE } from '../config';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
  /** Hide the right panel (e.g. on post pages where TOC takes its place). */
  hidePanel?: boolean;
  /** Constrain main content width (used by Pages like About/404). */
  narrow?: boolean;
  /** Breadcrumb segments shown in the topbar. */
  crumbs?: Array<{ label: string; href?: string }>;
  /** Pre-built SEO meta override. */
  seo?: SeoMeta;
}

const {
  title,
  description,
  ogImage,
  type = 'website',
  publishedTime,
  modifiedTime,
  tags,
  hidePanel = false,
  narrow = false,
  crumbs = [],
  seo,
} = Astro.props;

const t = useTranslations();
const lang = htmlLang();

const meta: SeoMeta =
  seo ??
  buildSeo({
    title,
    description,
    fullPath: Astro.url.pathname,
    ogImage,
    type,
    publishedTime,
    modifiedTime,
    tags,
  });

const breadcrumbItems =
  crumbs.length > 0
    ? [
        { label: t('nav.home'), href: new URL(withBase('/'), SITE.url).toString() },
        ...crumbs.map((crumb) => ({
          label: crumb.label,
          href: crumb.href ? new URL(withBase(crumb.href), SITE.url).toString() : meta.canonical,
        })),
      ]
    : [];

const breadcrumbJsonLd =
  breadcrumbItems.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumbItems.map((item, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: item.label,
          item: item.href,
        })),
      }
    : undefined;

const contentGridClass = hidePanel
  ? 'grid-cols-1'
  : 'grid-cols-1 xl:grid-cols-[minmax(0,1fr)_var(--width-panel)] min-[1440px]:grid-cols-[minmax(0,1fr)_15rem] min-[1650px]:grid-cols-[minmax(0,1fr)_16.25rem]';
---

<!doctype html>
<html lang={lang} data-theme="chirpy-light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f6f7f8" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#1b1b1e" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content={SITE.name} />
    <link rel="manifest" href={withBase('/manifest.json')} />
    <link rel="icon" type="image/png" href={withBase(faviconImg.src)} />
    <link rel="icon" type="image/png" sizes="64x64" href={withBase(favicon64Img.src)} />
    <link rel="icon" type="image/png" sizes="120x120" href={withBase(favicon120Img.src)} />
    <link rel="icon" type="image/png" sizes="180x180" href={withBase(favicon180Img.src)} />
    <link rel="icon" type="image/png" sizes="240x240" href={withBase(favicon240Img.src)} />
    <link rel="apple-touch-icon" sizes="120x120" href={withBase(favicon120Img.src)} />
    <link rel="apple-touch-icon" sizes="152x152" href={withBase(favicon152Img.src)} />
    <link rel="apple-touch-icon" sizes="167x167" href={withBase(favicon167Img.src)} />
    <link rel="apple-touch-icon" sizes="180x180" href={withBase(favicon180Img.src)} />
    <SEO meta={meta} />
    {
      breadcrumbJsonLd && (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
      )
    }
    {/* Custom fonts configured via Astro Fonts API */}
    <Font cssVariable="--font-source-sans-3" />
    <Font cssVariable="--font-lato" />
    <Font cssVariable="--font-jetbrains-mono" preload />
    <ClientRouter />
    {/* Apply system theme or session cookie override as early as possible to avoid FOUC. */}
    <script is:inline>
      (function () {
        var cookieName = 'theme';

        function systemTheme() {
          return window.matchMedia('(prefers-color-scheme: dark)').matches
            ? 'chirpy-dark'
            : 'chirpy-light';
        }

        function getThemeCookie() {
          var match = document.cookie.match(new RegExp('(?:^|; )' + cookieName + '=([^;]*)'));
          if (!match) return '';
          var value = decodeURIComponent(match[1]);
          return value === 'chirpy-dark' || value === 'chirpy-light' ? value : '';
        }

        function applyTheme() {
          try {
            localStorage.removeItem(cookieName);
            var theme = getThemeCookie() || systemTheme();
            document.documentElement.setAttribute('data-theme', theme);
          } catch {
            /* ignore */
          }
        }
        applyTheme();
        // Re-apply after view transitions swap in a fresh <html data-theme>.
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>
  </head>

  <body>
    <a
      href="#main"
      class="focus:bg-primary focus:text-primary-content sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:rounded focus:px-3 focus:py-2"
    >
      {t('site.skipToContent')}
    </a>

    <Sidebar />

    <div class="min-h-screen min-[1650px]:!ml-(--width-sidebar-lg) lg:ml-(--width-sidebar)">
      <Topbar crumbs={crumbs} />

      <div
        class:list={[
          'container mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:px-8',
          contentGridClass,
        ]}
      >
        <div class="flex min-w-0 flex-col">
          <main
            id="main"
            aria-label="Main Content"
            class:list={['min-w-0 flex-1 py-6 lg:pr-2', narrow ? 'mx-auto w-full max-w-3xl' : '']}
          >
            <slot />
          </main>

          <Footer />
        </div>

        {
          !hidePanel && (
            <aside class="hidden pt-6 text-sm xl:block [&>*+*]:mt-8" aria-label="Sidebar widgets">
              <Panel />
              <slot name="aside-bottom" />
            </aside>
          )
        }
      </div>
    </div>

    <BackToTop />
  </body>
</html>

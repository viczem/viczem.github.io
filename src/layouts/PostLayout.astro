---
import BaseLayout from './BaseLayout.astro';
import PostNav from '../components/PostNav.astro';
import SmartImage from '../components/SmartImage.astro';
import TableOfContents from '../components/islands/TableOfContents.astro';
import TelegramComments from '../components/islands/TelegramComments.astro';
import MathStyles from '../components/MathStyles.astro';
import { Icon } from 'astro-icon/components';
import { SITE, TELEGRAM_COMMENTS } from '../config';
import { useTranslations, formatDate, isoDate } from '../i18n/utils';
import { readingTime } from '../utils/reading-time';
import {
  type Post,
  tagPath,
  postSlug,
  heroImage,
  heroImageSrc,
  shouldShowHero,
} from '../utils/posts';
import { buildSeo } from '../utils/seo';
import type { MarkdownHeading } from 'astro';

interface Props {
  post: Post;
  /** Astro's `headings` array from `await render(post)`. */
  headings: MarkdownHeading[];
  /** Raw body string used for reading time. */
  body: string;
  prev?: Post;
  next?: Post;
}

const { post, headings, body, prev, next } = Astro.props;
const t = useTranslations();
const minutes = readingTime(body).minutes;

const commentsDisabled = post.data.comments === false;
const telegramCommentsEnabled =
  !commentsDisabled &&
  TELEGRAM_COMMENTS.enabled &&
  Boolean(TELEGRAM_COMMENTS.channel) &&
  Boolean(post.data.telegramPostId);

const heroSrc = heroImageSrc(post);
const heroAsset = heroImage(post);
const showHero = shouldShowHero(post);
const heroAlt = post.data.heroImageAlt ?? '';

const articleClass = SITE.boxedArticles
  ? 'border-base-300 bg-base-100 rounded-md border px-5 py-8 sm:px-8 sm:py-10'
  : '';

// Use hero image for OG if available, otherwise fallback to the generated OG image
// (unless Auto-OG is disabled globally or skipped in CI).
const ogSlug = postSlug(post);
const generatedOgPath = `/og/${ogSlug}.png`;
const skipAutoOg = !SITE.autoOgImage || import.meta.env.CI_SKIP_AUTO_OG_IMAGE === 'true';
const ogImage = heroSrc ?? (skipAutoOg ? undefined : generatedOgPath);

const seo = buildSeo({
  title: post.data.title,
  description: post.data.description,
  fullPath: Astro.url.pathname,
  ogImage,
  type: 'article',
  publishedTime: post.data.pubDate,
  modifiedTime: post.data.updatedDate,
  tags: post.data.tags,
  // An unlisted post hides from SEO by default unless the author
  // explicitly sets `unlistedHideFromSeo: false`.
  noindex: post.data.unlisted && (post.data.unlistedHideFromSeo ?? true),
});

const crumbs = [{ label: post.data.title }];
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  type="article"
  publishedTime={post.data.pubDate}
  modifiedTime={post.data.updatedDate}
  tags={post.data.tags}
  crumbs={crumbs}
  seo={seo}
>
  {post.data.math && <MathStyles />}
  {
    post.data.toc && headings.length > 0 && (
      <TableOfContents slot="aside-bottom" headings={headings} variant="desktop" />
    )
  }
  {
    post.data.toc && headings.length > 0 && (
      <TableOfContents headings={headings} variant="floating" />
    )
  }

  <article class={articleClass}>
    <header class="mb-8">
      <h1
        class="text-base-content text-3xl leading-tight font-extrabold tracking-tight sm:text-[2.25rem]"
      >
        {post.data.title}
      </h1>
      <p class="text-base-content/65 mt-3 text-lg">{post.data.description}</p>

      <div class="text-base-content/70 mt-5 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm">
        <span class="inline-flex items-center gap-1">
          <Icon name="lucide:calendar-days" width={14} height={14} />
          <time datetime={isoDate(post.data.pubDate)}>{formatDate(post.data.pubDate)}</time>
        </span>
        {
          post.data.updatedDate && (
            <span class="inline-flex items-center gap-1">
              <Icon name="lucide:check" width={14} height={14} />
              <time datetime={isoDate(post.data.updatedDate)}>
                {t('post.updatedOn')} {formatDate(post.data.updatedDate)}
              </time>
            </span>
          )
        }
        <span class="inline-flex items-center gap-1">
          <Icon name="lucide:clock" width={14} height={14} />
          {minutes}
          {t('post.readingTime')}
        </span>
      </div>
    </header>

    {
      showHero && heroAsset && (
        <figure class="post-hero mb-8">
          <div class="post-hero__frame">
            <SmartImage
              src={heroAsset}
              alt={heroAlt}
              class="post-hero__img"
              loading="eager"
              widths={[480, 768, 1024, 1280, 1600]}
              sizes="(max-width: 768px) 100vw, 1024px"
              quality={82}
            />
          </div>
          {heroAlt && (
            <figcaption class="text-base-content/70 mt-2 text-center text-xs">{heroAlt}</figcaption>
          )}
        </figure>
      )
    }

    <div class="prose-chirpy max-w-none">
      <slot />
    </div>

    {
      post.data.tags.length > 0 && (
        <footer class="mt-10 flex flex-wrap items-center gap-2">
          <span class="text-base-content/70 inline-flex h-6 w-6 items-center justify-center">
            <Icon
              name="lucide:tags"
              width={18}
              height={18}
              aria-label={t('post.tags')}
              role="img"
            />
          </span>
          {post.data.tags.map((tag) => (
            <a href={tagPath(tag)} class="post-tag text-xs">
              {tag}
            </a>
          ))}
        </footer>
      )
    }

    <PostNav prev={prev} next={next} />

    {
      telegramCommentsEnabled && post.data.telegramPostId ? (
        <TelegramComments postId={post.data.telegramPostId} />
      ) : (
        commentsDisabled && (
          <p class="text-base-content/70 mt-10 text-sm">{t('post.commentsDisabled')}</p>
        )
      )
    }
  </article>
</BaseLayout>

---
import { SITE } from '../config';
import { localizedPath, useTranslations } from '../i18n/utils';

const t = useTranslations();
const year = new Date().getFullYear();
const footerLeftText = SITE.footer.leftText?.trim();
const footerRightText = SITE.footer.rightText?.trim();
const showPrivacyPolicy = SITE.footer.showPrivacyPolicy ?? SITE.showPrivacyPolicy;
const showThemeCredits = SITE.footer.showThemeCredits ?? true;
const shouldRenderRightFooter = Boolean(footerRightText) || showThemeCredits;
const resolvedLeftText = footerLeftText
  ?.replaceAll('{year}', String(year))
  .replaceAll('{author}', SITE.author.name);
---

<footer
  aria-label="Site Info"
  class="text-base-content/70 mt-10 flex flex-col gap-1 py-6 text-xs lg:flex-row lg:items-center lg:justify-between"
>
  <p>
    {
      resolvedLeftText ? (
        resolvedLeftText
      ) : (
        <code class="text-gray-400">
          &copy;{' '}
          <a href={SITE.url ?? '#'} rel="noopener" class="hover:text-primary">
            {SITE.name}
          </a>
          , <time>{year}</time>. {t('footer.copyright')}
        </code>
      )
    }
    {
      showPrivacyPolicy && (
        <>
          {' '}
          <code class="text-gray-400">
            <a href={localizedPath('/privacy')} class="hover:text-primary">
              {t('footer.privacy')}
            </a>
          </code>
          .
        </>
      )
    }
  </p>
  {
    shouldRenderRightFooter && (
      <p>
        {footerRightText ? (
          <>
            {footerRightText}
            {showThemeCredits && (
              <>
                {' · '}
                {t('footer.theme')}{' '}
                <a href={SITE.footer.themeUrl} rel="noopener" class="hover:text-primary">
                  {SITE.footer.themeName}
                </a>
              </>
            )}
          </>
        ) : (
          <>
            {t('footer.poweredBy')}{' '}
            <a href="https://astro.build" rel="noopener" class="hover:text-primary">
              Astro
            </a>{' '}
            · {t('footer.theme')}{' '}
            <a href={SITE.footer.themeUrl} rel="noopener" class="hover:text-primary">
              {SITE.footer.themeName}
            </a>
          </>
        )}
      </p>
    )
  }
</footer>

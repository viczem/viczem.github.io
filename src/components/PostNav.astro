---
import { useTranslations } from '../i18n/utils';
import { type Post, postPath } from '../utils/posts';
import { Icon } from 'astro-icon/components';

interface Props {
  prev?: Post;
  next?: Post;
}

const { prev, next } = Astro.props;
const t = useTranslations();
---

<nav aria-label="Post navigation" class="mt-10 grid gap-4 sm:grid-cols-2">
  {
    prev ? (
      <a
        href={postPath(prev)}
        rel="prev"
        class="card bg-base-200 hover:bg-base-300 transition-colors"
      >
        <div class="card-body">
          <p class="text-base-content/70 text-xs tracking-wide uppercase">
            <Icon
              name="lucide:arrow-up"
              width={12}
              height={12}
              class="inline -rotate-90 align-baseline"
            />
            {t('post.previous')}
          </p>
          <p class="font-semibold">{prev.data.title}</p>
        </div>
      </a>
    ) : (
      <span aria-hidden="true" class="hidden sm:block" />
    )
  }

  {
    next ? (
      <a
        href={postPath(next)}
        rel="next"
        class="card bg-base-200 hover:bg-base-300 transition-colors sm:text-right"
      >
        <div class="card-body">
          <p class="text-base-content/70 text-xs tracking-wide uppercase">
            {t('post.next')}
            <Icon
              name="lucide:arrow-up"
              width={12}
              height={12}
              class="inline rotate-90 align-baseline"
            />
          </p>
          <p class="font-semibold">{next.data.title}</p>
        </div>
      </a>
    ) : (
      <span aria-hidden="true" class="hidden sm:block" />
    )
  }
</nav>

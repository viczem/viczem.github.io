---
import { useTranslations } from '../../i18n/utils';
import { Icon } from 'astro-icon/components';

const t = useTranslations();
---

<button
  type="button"
  class="chirpy-theme"
  data-theme-toggle
  aria-label={t('theme.toggle')}
  title={t('theme.toggle')}
>
  <span data-theme-icon="light" class="hidden">
    <Icon name="lucide:sun" width={16} height={16} aria-label={t('theme.light')} role="img" />
  </span>
  <span data-theme-icon="dark" class="hidden">
    <Icon name="lucide:moon" width={16} height={16} aria-label={t('theme.dark')} role="img" />
  </span>
</button>

<script>
  type Theme = 'chirpy-light' | 'chirpy-dark';
  const COOKIE_NAME = 'theme';
  const CHANNEL_NAME = 'theme';
  const VALID_THEMES: Theme[] = ['chirpy-light', 'chirpy-dark'];

  type ThemeWindow = Window & {
    __themeChannel?: BroadcastChannel;
    __themeSystemListenerBound?: boolean;
  };

  const themeWindow = window as ThemeWindow;

  function systemTheme(): Theme {
    return window.matchMedia('(prefers-color-scheme: dark)').matches
      ? 'chirpy-dark'
      : 'chirpy-light';
  }

  function themeCookie(): Theme | undefined {
    const match = document.cookie.match(new RegExp(`(?:^|; )${COOKIE_NAME}=([^;]*)`));
    if (!match) return undefined;
    const value = decodeURIComponent(match[1]) as Theme;
    return VALID_THEMES.includes(value) ? value : undefined;
  }

  function setThemeCookie(theme: Theme): void {
    document.cookie = `${COOKIE_NAME}=${encodeURIComponent(theme)}; Path=/; SameSite=Lax`;
  }

  function deleteThemeCookie(): void {
    document.cookie = `${COOKIE_NAME}=; Path=/; Max-Age=0; SameSite=Lax`;
  }

  function resolvedTheme(): Theme {
    return themeCookie() ?? systemTheme();
  }

  function currentTheme(): Theme {
    const theme = document.documentElement.getAttribute('data-theme') as Theme | null;
    return theme && VALID_THEMES.includes(theme) ? theme : resolvedTheme();
  }

  function commitTheme(theme: Theme, broadcast = true): void {
    document.documentElement.setAttribute('data-theme', theme);
    try {
      if (theme === systemTheme()) {
        deleteThemeCookie();
      } else {
        setThemeCookie(theme);
      }
    } catch {
      /* ignore */
    }
    updateIcons(theme);
    document.dispatchEvent(new CustomEvent('theme-change', { detail: { theme } }));
    if (broadcast) broadcastThemeChange();
  }

  function applyResolvedTheme(): void {
    const theme = resolvedTheme();
    document.documentElement.setAttribute('data-theme', theme);
    updateIcons(theme);
    document.dispatchEvent(new CustomEvent('theme-change', { detail: { theme } }));
  }

  function broadcastThemeChange(): void {
    try {
      themeWindow.__themeChannel?.postMessage({ type: 'theme-change' });
    } catch {
      /* ignore */
    }
  }

  function initCrossTabSync(): void {
    if (themeWindow.__themeChannel) return;
    try {
      themeWindow.__themeChannel = new BroadcastChannel(CHANNEL_NAME);
      themeWindow.__themeChannel.addEventListener('message', applyResolvedTheme);
    } catch {
      /* ignore */
    }
  }

  function initSystemThemeSync(): void {
    if (themeWindow.__themeSystemListenerBound) return;
    themeWindow.__themeSystemListenerBound = true;
    const mql = window.matchMedia('(prefers-color-scheme: dark)');
    mql.addEventListener('change', () => {
      try {
        if (themeCookie()) return;
      } catch {
        /* ignore */
      }
      applyResolvedTheme();
    });
  }

  /**
   * Apply a theme. When the View Transitions API is available and the
   * caller supplies a click event, animate a circular reveal from the
   * cursor; otherwise fall back to an instant swap.
   */
  function applyTheme(theme: Theme, origin?: { x: number; y: number }): void {
    const supportsVT =
      typeof (document as unknown as { startViewTransition?: unknown }).startViewTransition ===
      'function';
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!supportsVT || reduceMotion || !origin) {
      commitTheme(theme);
      return;
    }

    const root = document.documentElement;
    root.style.setProperty('--theme-x', `${origin.x}px`);
    root.style.setProperty('--theme-y', `${origin.y}px`);
    const dx = Math.max(origin.x, window.innerWidth - origin.x);
    const dy = Math.max(origin.y, window.innerHeight - origin.y);
    const radius = Math.hypot(dx, dy);
    root.style.setProperty('--theme-radius', `${radius}px`);
    root.dataset.themeAnim = theme === 'chirpy-dark' ? 'to-dark' : 'to-light';

    const transition = (
      document as unknown as {
        // eslint-disable-next-line no-unused-vars
        startViewTransition: (cb: () => void) => { finished: Promise<void> };
      }
    ).startViewTransition(() => {
      commitTheme(theme);
    });
    transition.finished.finally(() => {
      delete root.dataset.themeAnim;
    });
  }

  function updateIcons(theme: Theme): void {
    document.querySelectorAll<HTMLElement>('[data-theme-icon]').forEach((el) => {
      const want = theme === 'chirpy-dark' ? 'light' : 'dark';
      el.classList.toggle('hidden', el.dataset.themeIcon !== want);
    });
  }

  function init(): void {
    try {
      localStorage.removeItem(COOKIE_NAME);
    } catch {
      /* ignore */
    }

    applyResolvedTheme();

    document.querySelectorAll<HTMLElement>('[data-theme-toggle]').forEach((btn) => {
      btn.addEventListener('click', (event) => {
        const next: Theme = currentTheme() === 'chirpy-dark' ? 'chirpy-light' : 'chirpy-dark';
        const rect = btn.getBoundingClientRect();
        const origin = {
          x: (event as MouseEvent).clientX || rect.left + rect.width / 2,
          y: (event as MouseEvent).clientY || rect.top + rect.height / 2,
        };
        applyTheme(next, origin);
      });
    });

    initCrossTabSync();
    initSystemThemeSync();
  }

  // `astro:page-load` fires on initial load AND after each client-side
  // navigation (DOM is swapped so old listeners are gone). Using only
  // this event avoids double-binding on first load which would fire two
  // startViewTransition() calls and cancel the animation.
  document.addEventListener('astro:page-load', init);
</script>

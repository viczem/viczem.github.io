---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostList from '../../components/PostList.astro';
import { useTranslations, localizedPath } from '../../i18n/utils';
import { getPosts, getCategoriesWithCount, slugify } from '../../utils/posts';

interface Props {
  categoryName: string;
}

export async function getStaticPaths() {
  const locale = 'en';
  const cats = await getCategoriesWithCount(locale);
  return cats.map((c) => ({
    params: { category: slugify(c.name) },
    props: { categoryName: c.name } satisfies Props,
  }));
}

const { categoryName } = Astro.props as Props;
const { category } = Astro.params;
const locale = 'en';
const t = useTranslations(locale);
const posts = (await getPosts(locale)).filter((p) =>
  p.data.categories.some((c) => slugify(c) === category),
);
---

<BaseLayout
  title={categoryName}
  pathWithoutLocale={`/categories/${category}/`}
  crumbs={[
    { label: t('categories.title'), href: localizedPath('/categories/', locale) },
    { label: categoryName },
  ]}
>
  <header class="mb-6">
    <p class="text-base-content/70 text-sm tracking-wide uppercase">{t('list.categoryPosts')}</p>
    <h1 class="text-3xl font-bold tracking-tight">{categoryName}</h1>
    <p class="text-base-content/70 mt-1 text-sm">
      {posts.length}
      {posts.length === 1 ? t('list.totalPostsOne') : t('list.totalPosts')}
    </p>
  </header>
  <PostList posts={posts} locale={locale} />
</BaseLayout>

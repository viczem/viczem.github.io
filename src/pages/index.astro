---
import BaseLayout from '~/layouts/BaseLayout.astro';
import PostList from '~/components/PostList.astro';
import Pagination from '~/components/Pagination.astro';
import { SITE } from '~/config';
import { localizedPath } from '~/i18n/utils';
import { getPosts } from '~/utils/posts';

const posts = await getPosts();
const pageSize = SITE.postsPerPage;
const lastPage = Math.max(1, Math.ceil(posts.length / pageSize));
const currentPage = 1;
const pagePosts = posts.slice(0, pageSize);

const hrefForPage = (n: number) => localizedPath(n === 1 ? '/' : `/page/${n}/`);
---

<BaseLayout title={SITE.title} description={SITE.description}>
  <PostList posts={pagePosts} />
  <Pagination currentPage={currentPage} lastPage={lastPage} hrefForPage={hrefForPage} />
</BaseLayout>

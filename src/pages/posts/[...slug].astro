---
import { render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { getPosts, postSlug, sortPostsByDate, type Post } from '../../utils/posts';

interface Props {
  post: Post;
  prev?: Post;
  next?: Post;
}

export async function getStaticPaths() {
  const locale = 'en';
  const posts = await getPosts(locale);
  // Compute prev/next from a strictly chronological order so pinned
  // posts don't label a newer post as "Previous".
  const chronological = sortPostsByDate(posts);
  return posts.map((post) => {
    const i = chronological.findIndex((p) => p.id === post.id);
    return {
      params: { slug: postSlug(post) },
      props: {
        post,
        prev: chronological[i + 1],
        next: chronological[i - 1],
      } satisfies Props,
    };
  });
}

const { post, prev, next } = Astro.props as Props;
const { Content, headings } = await render(post);
const body = post.body ?? '';
---

<PostLayout post={post} headings={headings} body={body} prev={prev} next={next} locale="en">
  <Content />
</PostLayout>

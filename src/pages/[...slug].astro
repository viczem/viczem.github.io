---
import { render } from 'astro:content';
import PostLayout from '~/layouts/PostLayout.astro';
import { getPosts, getUnlistedPosts, postSlug, sortPostsByDate, type Post } from '~/utils/posts';

interface Props {
  post: Post;
  prev?: Post;
  next?: Post;
}

export async function getStaticPaths() {
  const posts = await getPosts();
  const unlistedPosts = await getUnlistedPosts();
  const chronological = sortPostsByDate(posts);
  const paths = [
    ...posts.map((post) => {
      const i = chronological.findIndex((p) => p.id === post.id);
      return {
        params: { slug: postSlug(post) },
        props: {
          post,
          prev: chronological[i + 1],
          next: chronological[i - 1],
        },
      };
    }),
    ...unlistedPosts.map((post) => ({
      params: { slug: postSlug(post) },
      props: { post, prev: undefined, next: undefined },
    })),
  ];
  return paths;
}

const { post, prev, next } = Astro.props as Props;
const { Content, headings } = await render(post);
const body = post.body ?? '';
---

<PostLayout
  post={post}
  headings={headings}
  body={body}
  prev={prev}
  next={next}
>
  <Content />
</PostLayout>

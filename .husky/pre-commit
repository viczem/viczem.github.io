#!/usr/bin/env sh

echo ""
echo "================================================="
echo " ⏳ Running pre-commit formatting & linting..."
echo "================================================="

# FORCE_COLOR=1 ensures the text remains colored inside VS Code's Git output
FORCE_COLOR=1 bunx lint-staged

# If the command above fails ($? is not 0), print a giant obvious banner.
if [ $? -ne 0 ]; then
  echo ""
  echo "================================================="
  echo " ❌ PRE-COMMIT FAILED"
  echo " Please scroll up to see the Prettier/ESLint errors."
  echo " Fix them and try committing again."
  echo "================================================="
  exit 1
fi
